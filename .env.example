# Copy this file to .env and fill in your values.
# The backend requires PostgreSQL — SQLite is not supported.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/yourdbname

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret

# ── AI / Chat ────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Company branding ─────────────────────────────────────────────────────────
COMPANY_NAME=Your Company Name
COMPANY_SCOPE=telecom services, pricing, plans, billing, and customer support
# Pricing injected into the AI assistant system prompt (leave blank to disable)
COMPANY_PRICING=Internet: Basic $15, Advanced $30 | Mobile: Basic $5, Pro $15

# Terms the translation service should never translate (comma-separated)
PROTECTED_TERMS=Your Company Name

# ── Seed account credentials ─────────────────────────────────────────────────
# These accounts are created/refreshed every time the backend starts.
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+10000000001
ADMIN_PASSWORD=Admin123!

AGENT_NAME=Support Agent
AGENT_EMAIL=agent@example.com
AGENT_PHONE=+10000000002
AGENT_PASSWORD=Agent123!

DEMO_ADMIN_NAME=Demo Customer
DEMO_ADMIN_EMAIL=customer@example.com
DEMO_ADMIN_PHONE=+10000000003
DEMO_ADMIN_PASSWORD=Customer123!

# ── Demo data seeding ────────────────────────────────────────────────────────
# Only applied on the very first startup (when no customers exist yet).
DEMO_EMAIL_DOMAIN=example.com
DEMO_PHONE_PREFIX=+1555
DEMO_USER_PASSWORD=DemoPass123!
